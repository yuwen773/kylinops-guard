# Maven / Java
backend/target/
*.jar
*.war
*.class

# H2 Database files
backend/data/
data/
*.mv.db
*.trace.db

# IDE
.idea/
*.iml
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Node (frontend, for Phase 2)
frontend/node_modules/
frontend/dist/

# Built frontend in backend (from build-standalone.sh or npm run build)
backend/src/main/resources/static/

# Temp / local scripts
.tmp-*.sh
run-test-and-capture.bat

# Logs
*.log
logs/

# Environment-specific
.env
.env.local

# Local tool / agent state (not source code)
.omc/
.reasonix/
docs/superpowers/

# Isolated workspaces (per superpowers:using-git-worktrees)
.worktrees/
worktrees/

# Maven build artifacts (classpath dumps, etc.)
backend/cp.txt

# LoongArch VM 申请说明（可能含个人账号信息）
2026中国软件杯大赛-龙芯虚拟机申请与登录说明.pdf
