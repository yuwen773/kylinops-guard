# ============================================================
# KylinOps Guard — 生产环境变量模板
# ============================================================
# 安装:
#   sudo cp deploy/config/kylinops.env.example /etc/kylinops/kylinops.env
#   sudo chown root:kylinops /etc/kylinops/kylinops.env
#   sudo chmod 0640 /etc/kylinops/kylinops.env
#   sudo -e /etc/kylinops/kylinops.env          # 填入真实值
#
# 约束 (P4-T1):
#   * 文件权限 0600 或 0640, owner root:kylinops
#   * DO NOT COMMIT ACTUAL VALUES — 此文件不进 git
#   * DB_PASSWORD / ADMIN_PASSWORD_HASH / LLM_API_KEY 必须填非空值, 否则
#     ProductionConfigValidator (P1-T3) 会阻止启动
# ============================================================

# ---- 数据库 (PostgreSQL) ----
# P1-T1/T2: prod 强制 PostgreSQL + Flyway
DB_URL=jdbc:postgresql://127.0.0.1:5432/kylinops
DB_USERNAME=kylinops
DB_PASSWORD=

# ---- 单管理员登录 (P2-T2) ----
# ADMIN_PASSWORD_HASH 必须用 BCrypt 生成, 范例:
#   htpasswd -bnBC 10 "" 'yourpassword' | tr -d ':\n' | sed 's/\$2y/\$2a/'
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# ---- LLM (P3-T1..T6) ----
# 生产默认 LLM_ENABLED=false — 启用 LLM 时填 LLM_BASE_URL / LLM_API_KEY / LLM_MODEL
LLM_ENABLED=false
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# ---- Spring 配置导入 ----
# 部署期 yml overlay (deploy/config/application-prod.yml 安装到 /etc/kylinops/)
SPRING_CONFIG_IMPORT=file:/etc/kylinops/application-prod.yml

# ---- JVM 调优 ----
# 768M heap + 256M metaspace 适合 4-8 GB 内存的 LoongArch VM
JAVA_OPTS=-Xms512m -Xmx768m -XX:MaxMetaspaceSize=256m -XX:+UseG1GC -Djava.security.egd=file:/dev/./urandom
